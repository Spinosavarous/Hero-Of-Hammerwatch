# =========================================================
# UNITY TEAM .gitignore (clean + practical)
# Put in project root
# =========================================================

# -------------------------
# Unity generated folders
# -------------------------
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/[Uu]ser[Ss]ettings/
sysinfo.txt

# -------------------------
# Addressables / generated
# -------------------------
/ServerData/
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/*/*.bin*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*

# -------------------------
# Visual Scripting generated
# -------------------------
/[Aa]ssets/Unity.VisualScripting.Generated/

# -------------------------
# IDE / editor files
# -------------------------
.vs/
.idea/
.vscode/
.consulo/

# -------------------------
# Solution / project files
# -------------------------
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.DotSettings.user

# -------------------------
# Logs / temp
# -------------------------
*.log
*.bak
*.old
*.orig
mono_crash.*
crashlytics-build.properties

# -------------------------
# OS junk
# -------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------
# Build outputs
# -------------------------
*.apk
*.aab
*.ipa
*.app
*.exe

# -------------------------
# Archives
# -------------------------
*.zip
*.rar
*.7z
*.tar
*.gz

# -------------------------
# Media exports / recordings
# -------------------------
*.mp4
*.mov
*.avi
*.mkv

# -------------------------
# Large source files often accidental
# Uncomment if your team never uses them
# -------------------------
# *.psd
# *.blend
# *.fbx
# *.wav

# -------------------------
# Keep important Unity folders tracked
# -------------------------
!/Assets/**
!/Packages/**
!/ProjectSettings/**
```

